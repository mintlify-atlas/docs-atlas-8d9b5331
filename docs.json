{
  "$schema": "https://mintlify.com/docs.json",
  "name": "QuickFind API",
  "theme": "sequoia",
  "colors": {
    "primary": "#94cb04",
    "light": "#545454",
    "dark": "#94cb04"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://media.brand.dev/288cc7c4-5cef-4376-950b-bdf0083eedae.png",
    "dark": "https://media.brand.dev/288cc7c4-5cef-4376-950b-bdf0083eedae.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Ludociel-26/API-Back-End-QuickFind"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Ludociel-26/API-Back-End-QuickFind"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
